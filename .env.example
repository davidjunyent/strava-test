# Strava API Credentials
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# Note: Activity IDs are now passed as command-line arguments
# Example: python sync_test.py 12345678 87654321

# Path to strava_activities repository (absolute path)
ACTIVITIES_REPO_PATH=/path/to/strava_activities

# Git commit author info
GIT_EMAIL=your.email@example.com
GIT_NAME=Your Name
